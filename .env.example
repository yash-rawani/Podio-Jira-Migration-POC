# Podio
PODIO_CLIENT_ID=your_podio_client_id
PODIO_CLIENT_SECRET=your_podio_client_secret
PODIO_APP_ID=your_podio_app_id
PODIO_APP_TOKEN=your_podio_app_token
PODIO_VPC_TARGET=US

# Jira
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=PPY
JIRA_ISSUE_TYPE=Bug

# Migration size
TAKE_COUNT=10 -- (This changes based on number of migration size)

# Attachments
MAX_ATTACHMENTS=10 -- (This changes based on number of migration size)
MAX_ATTACHMENT_SIZE_MB=50

# Retry / pacing
PODIO_MAX_RETRIES=10
PODIO_MAX_BACKOFF_SECONDS=120
PODIO_PACE_SECONDS=0.5
PODIO_ACTIVITY_PACE_SECONDS=0.8
PODIO_COMMENTS_PACE_SECONDS=0.2
